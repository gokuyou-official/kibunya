# Firebase Web SDK config
# ----------------------------------------------------------------------
# 取得方法:
#   1) firebase login
#   2) firebase projects:create kibunya-app --display-name "キブンヤ"
#   3) firebase use kibunya-app
#   4) firebase apps:create WEB kibunya-web
#   5) firebase apps:sdkconfig WEB --json
# 出力された firebaseConfig の各キーを下に貼り付けてください。
#
# このファイル (.env.example) はコミットされます。実値は .env に書き、
# .env は .gitignore 済みなのでコミットされません。
# ----------------------------------------------------------------------

# firebaseConfig.apiKey
EXPO_PUBLIC_FIREBASE_API_KEY=

# firebaseConfig.authDomain (通常は <projectId>.firebaseapp.com)
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=kibunya-app.firebaseapp.com

# firebaseConfig.projectId
EXPO_PUBLIC_FIREBASE_PROJECT_ID=kibunya-app

# firebaseConfig.storageBucket (通常は <projectId>.appspot.com)
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=kibunya-app.appspot.com

# firebaseConfig.messagingSenderId (数字のみ)
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# firebaseConfig.appId (例: 1:1234567890:web:abcdef123456)
EXPO_PUBLIC_FIREBASE_APP_ID=
